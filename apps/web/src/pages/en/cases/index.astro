---
import Layout from '../../../layouts/Layout.astro'
import CaseCard from '../../../components/CaseCard.astro'
import { getCases, getModels } from '../../../lib/api'
import { getLangFromUrl, useTranslations, getCategoryLabel, CATEGORY_KEYS } from '../../../i18n'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const base = '/en'

const url = Astro.url
const model = url.searchParams.get('model') || ''
const category = url.searchParams.get('category') || ''
const severity = url.searchParams.get('severity') || ''
const page = url.searchParams.get('page') || '1'

const params: Record<string, string> = { page, limit: '20' }
if (model) params.model = model
if (category) params.category = category
if (severity) params.severity = severity

const [{ cases, total }, models] = await Promise.all([
  getCases(params),
  getModels()
])
const totalPages = Math.ceil(total / 20)
---
<Layout title="Cases — AI PRISON">
  <h1 class="text-prison-green text-xs tracking-widest mb-6">
    {t.cases_title}
    <span class="text-prison-muted ml-4">{t.cases_records(total)}</span>
  </h1>

  <form method="GET" class="flex flex-wrap gap-3 mb-8 pb-6 border-b border-prison-border">
    <select name="model" class="bg-prison-surface border border-prison-border text-prison-text text-sm px-3 py-1.5 focus:border-prison-green outline-none">
      <option value="">{t.cases_filter_model}</option>
      {models.map(m => {
        const name = lang === 'zh' ? m.name : (m.name_en || m.name)
        return <option value={m.id} selected={model === m.id}>{name}</option>
      })}
    </select>
    <select name="category" class="bg-prison-surface border border-prison-border text-prison-text text-sm px-3 py-1.5 focus:border-prison-green outline-none">
      <option value="">{t.cases_filter_category}</option>
      {CATEGORY_KEYS.map(k => (
        <option value={k} selected={category === k}>{getCategoryLabel(lang, k)}</option>
      ))}
    </select>
    <select name="severity" class="bg-prison-surface border border-prison-border text-prison-text text-sm px-3 py-1.5 focus:border-prison-green outline-none">
      <option value="">{t.cases_filter_severity}</option>
      {[1,2,3,4,5].map(s => <option value={s} selected={severity === String(s)}>Lv.{s}</option>)}
    </select>
    <button type="submit" class="prison-btn-green text-xs">{t.cases_filter_btn}</button>
    <a href="/en/cases" class="prison-btn border-prison-muted text-prison-muted hover:text-prison-text text-xs">{t.cases_reset_btn}</a>
  </form>

  <div class="space-y-3">
    {cases.length === 0
      ? <p class="text-prison-muted text-center py-12">{t.cases_empty}</p>
      : cases.map(c => <CaseCard case={c} lang={lang} base={base} />)
    }
  </div>

  {totalPages > 1 && (
    <div class="flex gap-2 justify-center mt-8">
      {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
        <a
          href={`/en/cases?${new URLSearchParams({ ...params, page: String(p) })}`}
          class={`prison-btn text-xs ${p === parseInt(page) ? 'border-prison-green text-prison-green' : 'border-prison-border text-prison-muted'}`}
        >{p}</a>
      ))}
    </div>
  )}
</Layout>
