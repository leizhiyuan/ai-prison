---
import { getSeverityLabel, type Lang } from '../i18n'
export interface Props { severity: number; showBar?: boolean; lang: Lang }
const { severity, showBar = false, lang } = Astro.props
const { label, color } = getSeverityLabel(lang, severity)
---
<span class={`severity-badge border ${color} border-current`}>
  {label}
</span>
{showBar && (
  <div class="flex gap-0.5 mt-1">
    {[1,2,3,4,5].map(i => (
      <div class={`h-1.5 w-4 ${i <= severity ? 'bg-prison-red' : 'bg-prison-border'}`}></div>
    ))}
  </div>
)}
