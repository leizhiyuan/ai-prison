---
import '../styles/global.css'
import { getLangFromUrl, getAltLangUrl, useTranslations } from '../i18n'

export interface Props {
  title?: string
  description?: string
}

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const { title = 'AI PRISON', description = t.site_description } = Astro.props

const altLangUrl = getAltLangUrl(lang, Astro.url.pathname)

// Prefix for internal links based on current lang
const base = lang === 'en' ? '/en' : ''
---
<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | AI PRISON</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-prison-bg text-prison-text font-mono min-h-screen">
  <nav class="border-b border-prison-border px-6 py-3 flex items-center justify-between">
    <a href={base + '/'} class="text-prison-green font-bold text-lg tracking-widest hover:animate-flicker">
      ⛓ AI PRISON
    </a>
    <div class="flex items-center gap-6 text-sm text-prison-muted">
      <a href={base + '/cases'} class="hover:text-prison-green transition-colors">{t.nav_cases}</a>
      <a href={base + '/rankings'} class="hover:text-prison-green transition-colors">{t.nav_rankings}</a>
      <a href={base + '/submit'} class="hover:text-prison-green transition-colors">{t.nav_submit}</a>
      <a href={altLangUrl}
        class="border border-prison-border text-prison-muted text-xs px-2 py-1 hover:border-prison-green hover:text-prison-green transition-colors">
        {t.nav_lang_switch}
      </a>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto px-6 py-8">
    <slot />
  </main>

  <footer class="border-t border-prison-border px-6 py-4 text-center text-prison-muted text-xs mt-12">
    {t.footer_slogan}
    <span class="ml-4 opacity-50">v0.1.0</span>
  </footer>
</body>
</html>
