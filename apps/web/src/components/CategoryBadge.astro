---
import { getCategoryLabel, type Lang } from '../i18n'
export interface Props { category: string; lang: Lang }
const { category, lang } = Astro.props
const label = getCategoryLabel(lang, category)
---
<span class="inline-block border border-prison-muted text-prison-muted text-xs px-2 py-0.5">
  {label}
</span>
