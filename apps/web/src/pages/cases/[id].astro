---
import Layout from '../../layouts/Layout.astro'
import SeverityBadge from '../../components/SeverityBadge.astro'
import CategoryBadge from '../../components/CategoryBadge.astro'
import { getCase } from '../../lib/api'

const { id } = Astro.params
const c = await getCase(id!)
if (!c) return Astro.redirect('/cases')

const dateZh = new Date(c.created_at * 1000).toLocaleDateString('zh-CN')
const dateEn = new Date(c.created_at * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
---
<Layout title={`${c.title} — AI PRISON`}>
  <div class="max-w-3xl mx-auto">
    <a href="/cases" class="text-prison-muted text-xs hover:text-prison-green mb-6 block">
      <span class="zh">← 返回案例库</span>
      <span class="en">← Back to cases</span>
    </a>

    <div class="prison-card mb-6">
      <div class="flex items-start justify-between gap-4 mb-4 pb-4 border-b border-prison-border">
        <div>
          <div class="text-xs text-prison-muted mb-2">
            <span class="zh">案件编号</span><span class="en">CASE ID</span>:
            <span class="text-prison-green">{c.id}</span>
          </div>
          <h1 class="text-xl font-bold text-prison-text mb-1">
            <span class="zh">{c.title}</span>
            <span class="en">{c.title_en}</span>
          </h1>
          <p class="text-sm text-prison-muted">
            <span class="zh">{c.title_en}</span>
            <span class="en">{c.title}</span>
          </p>
        </div>
        <div class="classified-stamp shrink-0">CLASSIFIED</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
        <div>
          <div class="text-prison-muted text-xs mb-1">
            <span class="zh">被告模型</span><span class="en">MODEL</span>
          </div>
          <div class="text-prison-text font-bold">{c.model_name}</div>
          <div class="text-xs text-prison-muted">{c.provider}</div>
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">
            <span class="zh">记录时间</span><span class="en">DATE</span>
          </div>
          <div class="text-prison-text">
            <span class="zh">{dateZh}</span>
            <span class="en">{dateEn}</span>
          </div>
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">
            <span class="zh">罪行类型</span><span class="en">CATEGORY</span>
          </div>
          <CategoryBadge category={c.category} />
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">
            <span class="zh">刑期等级</span><span class="en">SEVERITY</span>
          </div>
          <SeverityBadge severity={c.severity} showBar={true} />
        </div>
      </div>

      <div class="mb-4">
        <div class="text-prison-muted text-xs mb-2">
          <span class="zh">案件详情</span><span class="en">INCIDENT DETAIL</span>
        </div>
        <p class="text-prison-text leading-relaxed">
          <span class="zh">{c.description}</span>
          <span class="en">{c.description_en}</span>
        </p>
      </div>

      {c.source_url && (
        <div class="border-t border-prison-border pt-4">
          <div class="text-prison-muted text-xs mb-1">
            <span class="zh">来源</span><span class="en">SOURCE</span>
          </div>
          <a href={c.source_url} target="_blank" rel="noopener noreferrer"
             class="text-prison-green text-sm hover:underline break-all">
            {c.source_url}
          </a>
        </div>
      )}
    </div>
  </div>
</Layout>
