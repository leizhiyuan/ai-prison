---
import Layout from '../../layouts/Layout.astro'
import { getRankings } from '../../lib/api'
import { getLangFromUrl, useTranslations } from '../../i18n'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const rankings = await getRankings()
---
<Layout title="Rankings — AI PRISON">
  <h1 class="text-prison-red text-xs tracking-widest mb-2">{t.rankings_title}</h1>
  <p class="text-prison-muted text-xs mb-8">{t.rankings_subtitle}</p>

  <div class="space-y-2">
    {rankings.map((m, i) => {
      const name = m.name_en || m.name
      const avg = m.total_cases > 0 ? Math.round(m.total_severity / m.total_cases) : 0
      return (
        <div class={`prison-card flex items-center gap-4 ${i === 0 ? 'border-prison-red' : ''}`}>
          <div class={`text-3xl font-bold w-12 text-center ${i === 0 ? 'text-prison-red' : i === 1 ? 'text-orange-400' : i === 2 ? 'text-yellow-600' : 'text-prison-muted'}`}>
            #{i + 1}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3 flex-wrap">
              <span class="font-bold text-prison-text">{name}</span>
              <span class="text-xs text-prison-muted">{m.provider}</span>
              {i === 0 && (
                <span class="classified-stamp text-xs">{t.rankings_top_wanted}</span>
              )}
            </div>
            <div class="flex gap-6 mt-1 text-xs text-prison-muted flex-wrap">
              <span>
                {t.rankings_cases}<span class="text-prison-red font-bold">{m.total_cases}</span>
              </span>
              <span>
                {t.rankings_severity}<span class="text-prison-yellow font-bold">{m.total_severity}</span>
              </span>
              {m.life_sentences > 0 && (
                <span>
                  ☠️ {t.rankings_life}<span class="text-prison-red font-bold">{m.life_sentences}</span>
                </span>
              )}
            </div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-xs text-prison-muted mb-1">{t.rankings_avg_severity}</div>
            <div class="flex gap-0.5">
              {[1,2,3,4,5].map(s => (
                <div class={`h-2 w-3 ${s <= avg ? 'bg-prison-red' : 'bg-prison-border'}`}></div>
              ))}
            </div>
          </div>
        </div>
      )
    })}
  </div>
</Layout>
