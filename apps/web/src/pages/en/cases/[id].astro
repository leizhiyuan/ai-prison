---
import Layout from '../../../layouts/Layout.astro'
import SeverityBadge from '../../../components/SeverityBadge.astro'
import CategoryBadge from '../../../components/CategoryBadge.astro'
import { getCase } from '../../../lib/api'
import { getLangFromUrl, useTranslations } from '../../../i18n'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const { id } = Astro.params
const c = await getCase(id!)
if (!c) return Astro.redirect('/en/cases')

const title = c.title_en || c.title
const titleAlt = c.title
const description = c.description_en || c.description
const modelName = c.model_name_en || c.model_name

const date = new Date(c.created_at * 1000).toLocaleDateString(
  t.case_date_locale,
  t.case_date_options ?? undefined
)
---
<Layout title={`${title} — AI PRISON`}>
  <div class="max-w-3xl mx-auto">
    <a href="/en/cases" class="text-prison-muted text-xs hover:text-prison-green mb-6 block">
      {t.case_back}
    </a>

    <div class="prison-card mb-6">
      <div class="flex items-start justify-between gap-4 mb-4 pb-4 border-b border-prison-border">
        <div>
          <div class="text-xs text-prison-muted mb-2">
            {t.case_id_label}: <span class="text-prison-green">{c.id}</span>
          </div>
          <h1 class="text-xl font-bold text-prison-text mb-1">{title}</h1>
          {titleAlt && <p class="text-sm text-prison-muted">{titleAlt}</p>}
        </div>
        <div class="classified-stamp shrink-0">CLASSIFIED</div>
      </div>

      <div class="grid grid-cols-2 gap-4 mb-6 text-sm">
        <div>
          <div class="text-prison-muted text-xs mb-1">{t.case_model_label}</div>
          <div class="text-prison-text font-bold">{modelName}</div>
          <div class="text-xs text-prison-muted">{c.provider}</div>
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">{t.case_date_label}</div>
          <div class="text-prison-text">{date}</div>
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">{t.case_category_label}</div>
          <CategoryBadge category={c.category} lang={lang} />
        </div>
        <div>
          <div class="text-prison-muted text-xs mb-1">{t.case_severity_label}</div>
          <SeverityBadge severity={c.severity} showBar={true} lang={lang} />
        </div>
      </div>

      <div class="mb-4">
        <div class="text-prison-muted text-xs mb-2">{t.case_detail_label}</div>
        <p class="text-prison-text leading-relaxed">{description}</p>
      </div>

      {c.source_url && (
        <div class="border-t border-prison-border pt-4">
          <div class="text-prison-muted text-xs mb-1">{t.case_source_label}</div>
          <a href={c.source_url} target="_blank" rel="noopener noreferrer"
             class="text-prison-green text-sm hover:underline break-all">
            {c.source_url}
          </a>
        </div>
      )}
    </div>
  </div>
</Layout>
