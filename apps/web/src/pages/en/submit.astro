---
import Layout from '../../layouts/Layout.astro'
import SubmitForm from '../../components/SubmitForm'
import { getModels } from '../../lib/api'
import { getLangFromUrl, useTranslations } from '../../i18n'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const models = await getModels()
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787'
---
<Layout title="Submit — AI PRISON">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-prison-green text-xs tracking-widest mb-2">{t.submit_title}</h1>
    <p class="text-prison-muted text-xs mb-8">{t.submit_subtitle}</p>
    <SubmitForm models={models} apiUrl={apiUrl} lang={lang} client:load />
  </div>
</Layout>
